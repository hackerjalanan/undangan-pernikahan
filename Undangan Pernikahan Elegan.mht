        </div>

        <!-- Detail Lokasi -->
        <div class="location-section">
            <div class="location-title">Tempat Acara</div>
            <div class="location-name">Gedung Sasana Kriya</div>
            <div class="location-address">Taman Mini Indonesia Indah (TMII), Jakarta Timur, DKI Jakarta</div>
            
            <!-- Link Google Maps (Ganti URL sesuai lokasi asli Anda) -->
