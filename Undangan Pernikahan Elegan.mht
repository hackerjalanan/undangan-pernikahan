.location-title { font-size: 12px; text-transform: uppercase; letter-spacing: 3px; color: rgb(138, 115, 34); margin-bottom: 8px; }

.location-name { font-size: 15px; font-weight: bold; color: rgb(34, 34, 34); margin-bottom: 4px; }

.location-address { font-size: 13px; color: rgb(102, 102, 102); padding: 0px 15px; }

.map-button { display: inline-block; background-color: rgb(26, 26, 26); color: rgb(255, 255, 255); text-decoration: none; font-size: 11px; text-transform: uppercase; letter-spacing: 2px; padding: 12px 25px; border-radius: 2px; margin-top: 15px; transition: background-color 0.3s; }

.map-button:hover { background-color: rgb(212, 175, 55); }

.footer-text { font-size: 12px; color: rgb(136, 136, 136); margin-top: 25px; font-style: italic; }
